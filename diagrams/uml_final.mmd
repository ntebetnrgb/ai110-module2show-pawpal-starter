classDiagram
    %% Phase 6 final — matches pawpal_system.py as implemented.

    class Task {
        +str description
        +str time
        +int duration_minutes
        +str priority
        +str frequency
        +str due_date
        +bool completed
        +int id
        +str pet_name
        +int minutes_since_midnight
        +int priority_rank
        +mark_complete() Task|None
        +_spawn_next() Task|None
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +int id
        +add_task(task) Task
        +remove_task(task)
        +task_count() int
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) Pet
        +get_pet(name) Pet|None
        +all_tasks() list~Task~
    }

    class Scheduler {
        +Owner owner
        +sort_by_time(tasks) list~Task~
        +sort_by_priority(tasks) list~Task~
        +filter_by_pet(name) list~Task~
        +filter_by_status(completed) list~Task~
        +todays_schedule() list~Task~
        +detect_conflicts() list~str~
        +complete_task(task) Task|None
        +explain_plan() str
        +save_to_json(path)
        +load_from_json(path) Scheduler
    }

    Owner "1" o-- "*" Pet : manages
    Pet "1" *-- "*" Task : owns
    Scheduler "1" --> "1" Owner : reads
